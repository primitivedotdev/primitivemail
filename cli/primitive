"""PrimitiveMail CLI - manage your self-hosted inbox."""

import argparse
import json
import os
import pwd
import re
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

VERSION = "0.1.0"

TEST_EMAIL_API_URL = "https://www.primitive.dev/api/v1/test-email"

# Doc 08's "Implementation sketch" points at doc 00's SDK-adoption rule for
# canonical-event validation in `emails read`. The public SDK helper
# `validate_email_received_event` validates the webhook-event shape (with
# `event`, `delivery`, `evt_` id), NOT the on-disk canonical stored by the
# watcher (watcher.ts writes a canonical-email object with no webhook envelope).
# Running that validator against the on-disk canonical would exit 5 on every
# real email. Until the SDK exposes a helper that targets the on-disk
# canonical shape specifically, the CLI treats JSON-parse success as the
# exit-5 threshold. This matches doc 08's intent ("exit 5 on corrupted data")
# without emitting a false positive on every well-formed email.


_CANONICAL_ID_RE = re.compile(r"^\d{8}T\d{6}Z-[0-9a-f]{8}$")


def _invoking_user_home() -> Path:
    """Return the invoking user's home directory, not root's under sudo.

    When a user runs `sudo primitive restart`, sudo sets HOME=/root, so
    Path.home() returns /root and the CLI looks for /root/primitivemail
    which does not exist. Prefer SUDO_USER's pw_dir when we are root via
    sudo. Non-sudo invocations (and direct-root invocations without
    SUDO_USER set) fall through to Path.home() unchanged.
    """
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user and sudo_user != "root" and os.geteuid() == 0:
        try:
            return Path(pwd.getpwnam(sudo_user).pw_dir)
        except KeyError:
            # SUDO_USER present but not in /etc/passwd; fall through.
            pass
    return Path.home()


def get_maildata_path(args):
    """Resolve maildata path from --path flag, env var, or default."""
    if args.path:
        return Path(args.path)
    if os.environ.get("PRIMITIVEMAIL_MAILDATA"):
        return Path(os.environ["PRIMITIVEMAIL_MAILDATA"])
    # Default: ~/primitivemail/maildata (resolved against the invoking
    # user's home, not /root under sudo).
    return _invoking_user_home() / "primitivemail" / "maildata"


def parse_filename_timestamp(filename):
    """Parse timestamp from filename like 20260311T225855Z-089ecb30.eml"""
    try:
        ts_str = filename.split("-")[0]  # 20260311T225855Z
        return datetime.strptime(ts_str, "%Y%m%dT%H%M%SZ").replace(tzinfo=timezone.utc)
    except (ValueError, IndexError):
        return None


def _tty_stderr(msg):
    """Write a human status line to stderr only when stderr is a TTY.

    Pipes and scripted consumers see a clean stderr; human operators see
    match counts and applied-filter summaries.
    """
    if sys.stderr.isatty():
        print(msg, file=sys.stderr)


def _journal_path(maildata: Path) -> Path:
    return maildata / "emails.jsonl"


def _is_tombstone(entry: dict) -> bool:
    """Tombstone schema (forward-compatible, design-captured in doc 22)."""
    return entry.get("type") == "tombstone"


def _iter_journal(path: Path, since_seq: int = 0, limit: int = 0):
    """Yield (offset_after_line, raw_line_bytes, parsed_entry) tuples.

    The journal is append-only and monotonic in `seq`; we stream forward.
    `since_seq=0` yields every entry. `limit=0` means no limit.

    Raises FileNotFoundError if the journal does not exist. Raises a
    ValueError wrapping (offset, excerpt, error) when a line is not valid
    JSON; callers map that to exit 5.
    """
    emitted = 0
    with open(path, "rb") as fh:
        offset = 0
        for raw in fh:
            offset += len(raw)
            stripped = raw.strip()
            if not stripped:
                continue
            try:
                entry = json.loads(stripped)
            except json.JSONDecodeError as exc:
                excerpt = stripped[:80].decode("utf-8", errors="replace")
                raise ValueError(
                    f"corrupt journal line at offset {offset - len(raw)}: "
                    f"{exc} (excerpt: {excerpt!r})"
                ) from exc
            seq = entry.get("seq")
            if not isinstance(seq, int):
                raise ValueError(
                    f"journal entry missing integer seq at offset {offset - len(raw)}"
                )
            if seq <= since_seq:
                continue
            yield offset, raw, entry
            emitted += 1
            if limit and emitted >= limit:
                return


def _resolve_id(maildata: Path, selector, *, domain=None, allow_prefix=False):
    """Resolve a selector to a concrete (domain, id) pair.

    Journal-authoritative. Filesystem globs are never used; the only
    filesystem access is an exact-path stat on known, sidecar-free
    suffixes performed by callers after this function returns. See doc 08
    "Id resolution: authoritative spec" for the full contract.

    Returns (domain, id) on success.

    Raises `ResolveError(exit_code, message)` on failure, where exit_code
    follows the shared exit-code scheme at the top of doc 08.
    """
    if not isinstance(selector, str) or not selector:
        raise ResolveError(2, "empty id selector")

    is_full_id = bool(_CANONICAL_ID_RE.match(selector))

    # Case 1: full id + explicit --domain. Exact-path stat only.
    if is_full_id and domain is not None:
        canonical = maildata / domain / f"{selector}.json"
        if canonical.exists():
            return (domain, selector)
        meta = maildata / domain / f"{selector}.meta.json"
        if meta.exists():
            # pre-canonical: watcher never produced <id>.json. Distinct from not-found.
            raise ResolveError(
                3,
                f"id {selector} under {domain} is pre-canonical "
                f"(meta.json exists, .json does not)",
            )
        raise ResolveError(1, f"id not found: {selector} under {domain}")

    # Reject invalid selectors before touching the filesystem. A non-full
    # id without --prefix can never match anything (the scan below is
    # guarded on is_full_id / allow_prefix), so there is no reason to walk
    # a potentially large journal just to raise exit 2.
    if not is_full_id and not allow_prefix:
        raise ResolveError(
            2,
            f"selector {selector!r} is not a full canonical id; "
            "pass a full id like 20260417T101203Z-a1b2c3d4 "
            "(--prefix is reserved for opt-in human use)",
        )

    journal = _journal_path(maildata)
    if not journal.exists():
        raise ResolveError(1, f"journal not found at {journal}")

    # Case 2 or 3: scan the journal (the authoritative source).
    matches = []  # list of (domain, id)
    try:
        for _, _, entry in _iter_journal(journal):
            if _is_tombstone(entry):
                continue
            entry_id = entry.get("id")
            entry_domain = entry.get("domain")
            if not isinstance(entry_id, str) or not isinstance(entry_domain, str):
                continue
            if is_full_id:
                if entry_id == selector:
                    matches.append((entry_domain, entry_id))
            elif allow_prefix:
                if entry_id.startswith(selector):
                    matches.append((entry_domain, entry_id))
    except ValueError as exc:
        raise ResolveError(5, str(exc)) from exc

    if not matches:
        raise ResolveError(1, f"id not found: {selector}")

    # Deduplicate identical (domain, id) pairs a tombstone-free forward
    # scan should never yield, but the journal may legitimately repeat
    # under recovery scenarios.
    unique = list(dict.fromkeys(matches))
    if len(unique) > 1:
        domains = sorted({d for d, _ in unique})
        raise ResolveError(
            3,
            f"ambiguous id {selector!r}: matches {len(unique)} entries "
            f"(domains: {', '.join(domains)})",
        )

    return unique[0]


def _resolve_seq(maildata: Path, seq: int):
    """Resolve a seq number to (domain, id) via the journal.

    Journal-authoritative: we never stat-scan domain directories. A seq
    that does not appear in the journal is exit 1 (not found), even if a
    canonical file happens to exist on disk with that sequence elsewhere.
    Tombstones are skipped; a caller asking for a tombstoned seq gets the
    same not-found as an unknown seq, which matches what `emails read`
    would do for any other deleted entry.
    """
    if seq < 1:
        raise ResolveError(2, f"seq must be >= 1, got {seq}")
    journal = _journal_path(maildata)
    if not journal.exists():
        raise ResolveError(1, f"journal not found at {journal}")
    try:
        for _, _, entry in _iter_journal(journal):
            if _is_tombstone(entry):
                continue
            if entry.get("seq") == seq:
                domain = entry.get("domain")
                entry_id = entry.get("id")
                if not isinstance(domain, str) or not isinstance(entry_id, str):
                    raise ResolveError(
                        5,
                        f"journal entry for seq {seq} is missing id or domain",
                    )
                return (domain, entry_id)
    except ValueError as exc:
        raise ResolveError(5, str(exc)) from exc
    raise ResolveError(1, f"seq {seq} not found in journal")


def _resolve_latest(maildata: Path):
    """Resolve the most recent non-tombstone journal entry to (domain, id).

    "Most recent" is the last entry emitted by the forward-scan iterator,
    which matches journal order (i.e., received_at order for correctly-
    written journals). Tombstones are skipped so `--latest` always points
    at a readable email.
    """
    journal = _journal_path(maildata)
    if not journal.exists():
        raise ResolveError(1, f"journal not found at {journal}")
    latest = None
    try:
        for _, _, entry in _iter_journal(journal):
            if _is_tombstone(entry):
                continue
            latest = entry
    except ValueError as exc:
        raise ResolveError(5, str(exc)) from exc
    if latest is None:
        raise ResolveError(1, "no emails in journal")
    domain = latest.get("domain")
    entry_id = latest.get("id")
    if not isinstance(domain, str) or not isinstance(entry_id, str):
        raise ResolveError(
            5,
            "latest journal entry is missing id or domain",
        )
    return (domain, entry_id)


class ResolveError(Exception):
    def __init__(self, exit_code, message):
        super().__init__(message)
        self.exit_code = exit_code
        self.message = message


def _iso_timestamp(s):
    """Parse an ISO-8601 UTC timestamp for `emails count --since`.

    Rejects non-UTC values (no offset other than Z or +00:00) so the
    contract is unambiguous. Raises ValueError on any invalid input.
    """
    if not isinstance(s, str) or not s:
        raise ValueError("empty timestamp")
    normalized = s[:-1] + "+00:00" if s.endswith("Z") else s
    try:
        parsed = datetime.fromisoformat(normalized)
    except ValueError as exc:
        raise ValueError(f"not a valid ISO-8601 timestamp: {s!r}") from exc
    if parsed.tzinfo is None:
        raise ValueError(f"timestamp must be UTC (e.g. ...Z): {s!r}")
    if parsed.utcoffset() != timezone.utc.utcoffset(None):
        raise ValueError(f"timestamp must be UTC (offset must be 0): {s!r}")
    return parsed


def cmd_version(args):
    print(f"primitive {VERSION}")


def cmd_emails_status(args):
    maildata = get_maildata_path(args)

    if not maildata.exists():
        print(f"No maildata directory found at {maildata}")
        sys.exit(1)

    # Find all .eml files across all domain dirs
    eml_files = sorted(maildata.glob("*/*.eml"))
    total = len(eml_files)

    if total == 0:
        print("No emails received yet.")
        return

    # Most recent email (filenames sort chronologically)
    latest_eml = eml_files[-1]
    latest_meta = latest_eml.with_suffix(".meta.json")

    # Parse timestamp from filename
    received_at = parse_filename_timestamp(latest_eml.name)
    received_str = received_at.strftime("%Y-%m-%d %H:%M:%S UTC") if received_at else "unknown"

    # Read sender from .meta.json
    sender = "unknown"
    if latest_meta.exists():
        try:
            meta = json.loads(latest_meta.read_text())
            sender = meta.get("smtp", {}).get("mail_from", "unknown")
        except (json.JSONDecodeError, OSError):
            pass

    print(f"Total emails:  {total}")
    print(f"Last received: {received_str}")
    print(f"Last from:     {sender}")


def cmd_emails_status_alias(args):
    """Hidden compatibility shim for the old `emails-status` command.

    Drops one release cycle after the `emails status` rename. See doc 08
    "Compatibility notes".
    """
    print(
        "warning: `primitive emails-status` is deprecated; "
        "use `primitive emails status`",
        file=sys.stderr,
    )
    cmd_emails_status(args)


def cmd_emails_list(args):
    maildata = get_maildata_path(args)
    if not maildata.exists():
        print(f"No maildata directory found at {maildata}", file=sys.stderr)
        sys.exit(1)

    if args.limit is not None and args.limit < 0:
        print("--limit must be >= 0 (0 means unlimited)", file=sys.stderr)
        sys.exit(2)

    journal = _journal_path(maildata)
    if not journal.exists():
        # Empty inbox, not an error.
        _tty_stderr("no emails (journal not yet created)")
        return

    limit = args.limit if args.limit is not None else 20
    since = args.since or 0

    matched = []
    try:
        for _, raw, entry in _iter_journal(journal, since_seq=since):
            if _is_tombstone(entry):
                continue
            if args.domain and entry.get("domain") != args.domain:
                continue
            if args.from_addr:
                from_addr = entry.get("from_address") or ""
                if args.from_addr not in from_addr:
                    continue
            matched.append((raw, entry))
            # `limit=0` is unlimited; otherwise stop once we have `limit`.
            if limit and len(matched) >= limit:
                break
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        sys.exit(5)

    if args.json:
        out = sys.stdout.buffer
        for raw, _ in matched:
            out.write(raw if raw.endswith(b"\n") else raw + b"\n")
        out.flush()
    else:
        _print_list_human(matched)

    filters = []
    if args.domain:
        filters.append(f"domain={args.domain}")
    if args.from_addr:
        filters.append(f"from~={args.from_addr}")
    if since:
        filters.append(f"since={since}")
    filter_str = f" ({', '.join(filters)})" if filters else ""
    _tty_stderr(f"{len(matched)} match(es){filter_str}")
    # Nudge first-timers toward the read command. Only shown on an
    # interactive stderr so scripted / piped consumers stay clean.
    if matched and not args.json:
        _tty_stderr("Read with: primitive emails read <id|seq> "
                    "[--latest] [--format text|html|json|raw]")


def _print_list_human(rows):
    if not rows:
        return
    widths = {"seq": len("seq"), "received_at": len("received_at"), "from": len("from_address")}
    normalized = []
    for _, entry in rows:
        seq = str(entry.get("seq", ""))
        received = str(entry.get("received_at", ""))
        from_addr = str(entry.get("from_address") or "")
        subject = str(entry.get("subject") or "")
        widths["seq"] = max(widths["seq"], len(seq))
        widths["received_at"] = max(widths["received_at"], len(received))
        widths["from"] = max(widths["from"], len(from_addr))
        normalized.append((seq, received, from_addr, subject))
    header = (
        f"{'seq'.ljust(widths['seq'])}  "
        f"{'received_at'.ljust(widths['received_at'])}  "
        f"{'from_address'.ljust(widths['from'])}  subject"
    )
    print(header)
    for seq, received, from_addr, subject in normalized:
        print(
            f"{seq.ljust(widths['seq'])}  "
            f"{received.ljust(widths['received_at'])}  "
            f"{from_addr.ljust(widths['from'])}  {subject}"
        )


def cmd_emails_read(args):
    maildata = get_maildata_path(args)
    if not maildata.exists():
        print(f"No maildata directory found at {maildata}", file=sys.stderr)
        sys.exit(1)

    # Three ways to pick an entry:
    #   --latest        -> most recent non-tombstone journal entry
    #   digits only     -> seq lookup (disjoint from the canonical-id regex,
    #                      which always has "T" and "-", so no ambiguity)
    #   otherwise       -> canonical id (exact) or, with --prefix, a prefix
    # --latest is mutually exclusive with a positional selector.
    if args.latest and args.selector is not None:
        print("--latest and a positional <selector> are mutually exclusive",
              file=sys.stderr)
        sys.exit(2)
    if not args.latest and args.selector is None:
        print("provide a selector (canonical id or seq number) or use --latest",
              file=sys.stderr)
        sys.exit(2)

    try:
        if args.latest:
            domain, resolved_id = _resolve_latest(maildata)
        elif args.prefix:
            # --prefix is an explicit opt-in to prefix matching. It must
            # take precedence over the digits-as-seq shortcut, otherwise
            # `emails read --prefix 20260417` silently becomes a seq
            # lookup for 20,260,417 and the flag appears dropped.
            domain, resolved_id = _resolve_id(
                maildata, args.selector,
                domain=args.domain, allow_prefix=True,
            )
        elif args.selector.isdigit():
            domain, resolved_id = _resolve_seq(maildata, int(args.selector))
        else:
            domain, resolved_id = _resolve_id(
                maildata, args.selector,
                domain=args.domain, allow_prefix=False,
            )
    except ResolveError as exc:
        print(exc.message, file=sys.stderr)
        sys.exit(exc.exit_code)

    domain_dir = maildata / domain
    fmt = args.format

    if fmt == "raw":
        eml_path = domain_dir / f"{resolved_id}.eml"
        if not eml_path.exists():
            print(f"raw .eml not found: {eml_path}", file=sys.stderr)
            sys.exit(1)
        try:
            with open(eml_path, "rb") as fh:
                sys.stdout.buffer.write(fh.read())
            sys.stdout.buffer.flush()
        except OSError as exc:
            print(f"could not read {eml_path}: {exc}", file=sys.stderr)
            sys.exit(1)
        return

    canonical_path = domain_dir / f"{resolved_id}.json"
    if not canonical_path.exists():
        print(f"canonical json not found: {canonical_path}", file=sys.stderr)
        sys.exit(1)

    # Read the canonical exactly once and parse it once. --format json
    # emits the raw bytes verbatim (preserving key order and whitespace);
    # --format text/html reads fields off the parsed dict. Splitting the
    # read between `read_text()` inside a helper and a follow-up
    # `read_bytes()` doubled the I/O and introduced a TOCTOU window.
    try:
        content = canonical_path.read_bytes()
        event = json.loads(content)
        if not isinstance(event, dict):
            raise ValueError("canonical event is not a JSON object")
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        print(f"{canonical_path}: {exc}", file=sys.stderr)
        sys.exit(5)

    if fmt == "json":
        sys.stdout.buffer.write(content)
        if not content.endswith(b"\n"):
            sys.stdout.buffer.write(b"\n")
        sys.stdout.buffer.flush()
        return

    # The on-disk canonical is a flat object (keys: id, received_at, smtp,
    # headers, auth, parsed, content), NOT wrapped in an `email` envelope.
    # That wrapper only appears in the SDK's webhook-delivery shape, not
    # in what the watcher writes to disk. `parsed` lives directly on the
    # canonical. Validate its shape so a malformed canonical exits 5
    # instead of raising AttributeError.
    parsed = event.get("parsed")
    if parsed is None:
        parsed = {}
    elif not isinstance(parsed, dict):
        print(
            f"{canonical_path}: malformed canonical (parsed is not an object)",
            file=sys.stderr,
        )
        sys.exit(5)
    if fmt == "text":
        body = parsed.get("body_text")
        if not body:
            print("no body_text on this email", file=sys.stderr)
            sys.exit(1)
        print(body)
        return
    if fmt == "html":
        body = parsed.get("body_html")
        if not body:
            print("no body_html on this email", file=sys.stderr)
            sys.exit(1)
        print(body)
        return


def cmd_emails_since(args):
    maildata = get_maildata_path(args)
    if not maildata.exists():
        print(f"No maildata directory found at {maildata}", file=sys.stderr)
        sys.exit(1)
    journal = _journal_path(maildata)
    if not journal.exists():
        print(f"journal not found at {journal}", file=sys.stderr)
        sys.exit(1)

    try:
        since_seq = int(args.seq)
    except (TypeError, ValueError):
        print(f"invalid <seq>: {args.seq!r} (must be a non-negative integer)", file=sys.stderr)
        sys.exit(2)
    if since_seq < 0:
        print("<seq> must be >= 0", file=sys.stderr)
        sys.exit(2)
    if args.limit is not None and args.limit < 0:
        print("--limit must be >= 0", file=sys.stderr)
        sys.exit(2)

    limit = args.limit if args.limit is not None else 0

    out = sys.stdout.buffer
    last_seq = since_seq
    emitted = 0

    def _emit(raw_bytes, entry):
        nonlocal last_seq, emitted
        out.write(raw_bytes if raw_bytes.endswith(b"\n") else raw_bytes + b"\n")
        out.flush()
        last_seq = entry.get("seq", last_seq)
        emitted += 1

    # Catch-up phase: scan forward from current EOF.
    # Exit 5 paths here emit `last_seq=<N>` on stderr before exiting, so a
    # consumer can resume from the last good entry regardless of which phase
    # the corruption surfaced in. The follow phase has the same guarantee;
    # the two shapes match so callers do not need phase-aware parsers.
    try:
        offset = 0
        with open(journal, "rb") as fh:
            for raw in fh:
                offset += len(raw)
                stripped = raw.strip()
                if not stripped:
                    continue
                try:
                    entry = json.loads(stripped)
                except json.JSONDecodeError as exc:
                    print(f"last_seq={last_seq}", file=sys.stderr)
                    print(
                        f"corrupt journal line at offset {offset - len(raw)}: {exc}",
                        file=sys.stderr,
                    )
                    sys.exit(5)
                seq = entry.get("seq")
                if not isinstance(seq, int):
                    print(f"last_seq={last_seq}", file=sys.stderr)
                    print(
                        f"journal entry missing integer seq at offset {offset - len(raw)}",
                        file=sys.stderr,
                    )
                    sys.exit(5)
                if seq <= last_seq:
                    continue
                _emit(raw, entry)
                if limit and emitted >= limit:
                    if not args.follow:
                        return
                    break
    except OSError as exc:
        print(f"could not read journal: {exc}", file=sys.stderr)
        sys.exit(1)

    if not args.follow:
        return

    # Follow phase: poll file size, read complete lines from current offset,
    # exit 4 on rotation or truncation. See doc 07 "Rotation and follow-race".
    try:
        st = os.stat(journal)
    except OSError as exc:
        print(f"journal disappeared: {exc}", file=sys.stderr)
        sys.exit(4)
    inode = st.st_ino
    size = offset  # everything through catch-up is consumed
    # One extra forward read to close the catch-up / follow handoff race.
    try:
        with open(journal, "rb") as fh:
            fh.seek(size)
            remaining = fh.read()
        size += _emit_complete_lines(remaining, _emit)
    except OSError as exc:
        print(f"follow read failed: {exc}", file=sys.stderr)
        sys.exit(4)
    except _FollowCorruption as exc:
        print(f"last_seq={last_seq}", file=sys.stderr)
        print(str(exc), file=sys.stderr)
        sys.exit(5)

    # Per doc 07: --limit caps catch-up only; follow-mode streaming runs
    # uncapped once catch-up is complete.
    try:
        while True:
            try:
                st = os.stat(journal)
            except FileNotFoundError:
                print(f"last_seq={last_seq}", file=sys.stderr)
                print("journal disappeared", file=sys.stderr)
                sys.exit(4)
            if st.st_ino != inode:
                print(f"last_seq={last_seq}", file=sys.stderr)
                print("journal rotated (inode changed)", file=sys.stderr)
                sys.exit(4)
            if st.st_size < size:
                print(f"last_seq={last_seq}", file=sys.stderr)
                print("journal truncated", file=sys.stderr)
                sys.exit(4)
            if st.st_size > size:
                try:
                    with open(journal, "rb") as fh:
                        fh.seek(size)
                        chunk = fh.read(st.st_size - size)
                except OSError as exc:
                    print(f"follow read failed: {exc}", file=sys.stderr)
                    sys.exit(4)
                try:
                    size += _emit_complete_lines(chunk, _emit)
                except _FollowCorruption as exc:
                    print(f"last_seq={last_seq}", file=sys.stderr)
                    print(str(exc), file=sys.stderr)
                    sys.exit(5)
                if size < st.st_size:
                    # Writer appended a partial (non-\n-terminated) line.
                    # Sleep before the next stat so we don't busy-spin on
                    # the same unconsumed bytes while waiting for the
                    # line terminator.
                    time.sleep(0.25)
                continue
            time.sleep(0.25)
    except KeyboardInterrupt:
        # SIGINT: report last_seq and exit 0 per doc 07.
        print(f"last_seq={last_seq}", file=sys.stderr)
        sys.exit(0)


class _FollowCorruption(Exception):
    """Corruption detected mid-follow.

    Raised by `_emit_complete_lines` instead of calling sys.exit directly so
    the caller can emit `last_seq=<N>` to stderr before exiting 5, matching
    the convention every exit-4 path in the follow loop already uses. Without
    this, consumers parsing `last_seq=` from stderr cannot resume after a
    corruption event.
    """


def _emit_complete_lines(buf: bytes, emit):
    """Emit complete lines from buf using the given emit callable.

    Returns the number of bytes consumed (the offset of the last newline).
    A trailing partial line is not emitted, matching `tail -f` semantics.

    Raises `_FollowCorruption` on bad JSON or a missing integer seq. The
    caller is expected to report `last_seq` and exit 5.
    """
    consumed = 0
    lines = buf.split(b"\n")
    # If the buffer ended with \n, the last split entry is "".
    # If it ended mid-line, keep that tail unconsumed.
    for line in lines[:-1]:
        raw = line + b"\n"
        stripped = line.strip()
        consumed += len(raw)
        if not stripped:
            continue
        try:
            entry = json.loads(stripped)
        except json.JSONDecodeError as exc:
            raise _FollowCorruption(f"corrupt journal line during follow: {exc}") from exc
        seq = entry.get("seq")
        if not isinstance(seq, int):
            raise _FollowCorruption("journal entry missing integer seq during follow")
        emit(raw, entry)
    return consumed


def cmd_emails_count(args):
    maildata = get_maildata_path(args)
    if not maildata.exists():
        print(f"No maildata directory found at {maildata}", file=sys.stderr)
        sys.exit(1)

    since_ts = None
    if args.since:
        try:
            since_ts = _iso_timestamp(args.since)
        except ValueError as exc:
            print(f"--since: {exc}", file=sys.stderr)
            sys.exit(2)

    journal = _journal_path(maildata)
    if not journal.exists():
        # No journal, no emails. Matches "empty result is still success".
        print(0)
        _tty_stderr("0 match(es) (no journal)")
        return

    count = 0
    try:
        for _, _, entry in _iter_journal(journal):
            if _is_tombstone(entry):
                continue
            if args.domain and entry.get("domain") != args.domain:
                continue
            if args.from_addr:
                from_addr = entry.get("from_address") or ""
                if args.from_addr not in from_addr:
                    continue
            if since_ts is not None:
                received = entry.get("received_at")
                if not isinstance(received, str):
                    continue
                try:
                    received_dt = _iso_timestamp(received)
                except ValueError:
                    continue
                if received_dt < since_ts:
                    continue
            count += 1
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        sys.exit(5)

    print(count)
    filters = []
    if args.domain:
        filters.append(f"domain={args.domain}")
    if args.from_addr:
        filters.append(f"from~={args.from_addr}")
    if args.since:
        filters.append(f"since={args.since}")
    filter_str = f" ({', '.join(filters)})" if filters else ""
    _tty_stderr(f"{count} match(es){filter_str}")


def _post_test_email(url, *, max_time=30):
    """POST an empty body to `url`, return (status, body_text).

    Forces IPv4 via `curl -4` to match the server-side IP lookup table
    (same rationale as claim_subdomain in installer/config.py; dual-stack
    clients can otherwise present a v6 address the server has not seen).

    Raises OSError when curl cannot reach the endpoint (DNS, connect
    refused, timeout, malformed http_code). Non-2xx responses are
    returned as a status + body for the caller to inspect.
    """
    try:
        result = subprocess.run(
            ["curl", "-4", "-s", "-X", "POST", url,
             "-H", "Content-Type: application/json",
             "-d", "{}",
             # Append the status on its own line after the body so the
             # two can be split cleanly. Use ASCII Record Separator (\x1e)
             # so a JSON body containing newlines does not confuse us.
             "-w", "\x1e%{http_code}",
             "--max-time", str(max_time)],
            capture_output=True, text=True, timeout=max_time + 5,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise OSError(str(exc)) from exc
    if result.returncode != 0:
        raise OSError(
            f"curl exit {result.returncode}: "
            f"{result.stderr.strip() or 'network error'}",
        )
    body, _, status_str = result.stdout.rpartition("\x1e")
    try:
        status = int(status_str.strip())
    except ValueError:
        raise OSError(f"curl returned malformed http_code: {status_str!r}")
    return status, body


def cmd_emails_test(args):
    # Doc 08b: --timeout between 5 and 120 inclusive. Reject out-of-range
    # values before any network call (exit 2 per the shared scheme).
    if args.timeout < 5 or args.timeout > 120:
        print("--timeout must be between 5 and 120 seconds", file=sys.stderr)
        sys.exit(2)

    # Dispatch the POST. A network-layer failure (DNS, connect refused,
    # malformed http_code) is exit 7 per doc 08b.
    try:
        status, body_str = _post_test_email(TEST_EMAIL_API_URL)
    except OSError as exc:
        if args.json:
            print(json.dumps({
                "ok": False, "error": "transport",
                "message": f"could not reach primitive.dev: {exc}",
            }))
        else:
            print(f"could not reach primitive.dev: {exc}", file=sys.stderr)
        sys.exit(7)

    # Parse the response body. A 2xx with unparseable JSON is corruption
    # at the wire level and still a transport error.
    try:
        body = json.loads(body_str) if body_str else {}
    except json.JSONDecodeError:
        msg = (f"primitive.dev returned a malformed response "
               f"(status {status}): {body_str[:512]!r}")
        if args.json:
            print(json.dumps({"ok": False, "error": "transport", "message": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(7)

    if status == 404 and body.get("error") == "no_subdomain_claimed":
        msg = body.get("message", "no subdomain claimed from this IP")
        hint = (msg + " Run `curl -fsSL https://get.primitive.dev | bash -s -- "
                "--claim-subdomain` from this host, or verify the outbound IP "
                "matches the one that originally claimed the domain.")
        if args.json:
            print(json.dumps({
                "ok": False, "error": "no_subdomain_claimed", "hint": hint,
            }))
        else:
            print(hint, file=sys.stderr)
        sys.exit(1)

    if status == 429 and body.get("error") == "rate_limited":
        msg = body.get("message", "rate limit reached")
        if args.json:
            print(json.dumps({
                "ok": False, "error": "rate_limited", "message": msg,
                "reset_at": body.get("reset_at"),
                "limit": body.get("limit"),
                "window_seconds": body.get("window_seconds"),
            }))
        else:
            print(msg, file=sys.stderr)
        sys.exit(4)

    if status < 200 or status >= 300:
        msg = (f"primitive.dev returned {status}: {body_str[:512]}")
        if args.json:
            print(json.dumps({
                "ok": False, "error": "transport",
                "status": status, "message": msg,
            }))
        else:
            print(msg, file=sys.stderr)
        sys.exit(7)

    # 200 but missing any of the fields we need to match on later.
    tag = body.get("tag")
    subject = body.get("subject")
    if not body.get("ok") or not isinstance(tag, str) or not isinstance(subject, str):
        msg = f"primitive.dev returned a malformed success response: {body_str[:512]}"
        if args.json:
            print(json.dumps({"ok": False, "error": "transport", "message": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(7)

    dispatched_at = body.get("dispatched_at")
    to_addr = body.get("to", "")
    from_addr = body.get("from", "")

    if not args.wait:
        if args.json:
            print(json.dumps({
                "ok": True, "tag": tag, "subject": subject,
                "dispatched_at": dispatched_at, "to": to_addr,
                "wait": False,
            }))
        else:
            print(f"Dispatched test email to {to_addr} (tag {tag}). "
                  f"Expect delivery within seconds. Check `primitive emails list`.")
        return

    # --wait path: poll emails.jsonl for a line whose `subject` field matches
    # the server-stamped subject verbatim. Seek to current EOF FIRST so a
    # stale tag in the journal from a prior run can never be picked up.
    if not args.json:
        print(f"Dispatching test email from primitive.dev to {to_addr}...")

    maildata = get_maildata_path(args)
    journal = _journal_path(maildata)
    try:
        start_size = journal.stat().st_size if journal.exists() else 0
    except OSError as exc:
        print(f"journal unreadable at {journal}: {exc}", file=sys.stderr)
        sys.exit(5)

    # Use monotonic for both the timeout budget and the elapsed figure so
    # they share a source that cannot jump under clock drift. elapsed_ms
    # measures the wait from the start of the poll phase (after the server
    # ack is in) until the matching journal entry lands. That is what the
    # operator cares about: "how long from dispatch to local receipt".
    poll_start = time.monotonic()
    deadline = poll_start + args.timeout

    matched = None
    scan_offset = start_size
    while time.monotonic() < deadline:
        try:
            if not journal.exists():
                time.sleep(0.5)
                continue
            with open(journal, "rb") as fh:
                fh.seek(scan_offset)
                chunk = fh.read()
        except OSError as exc:
            print(f"journal unreadable at {journal}: {exc}", file=sys.stderr)
            sys.exit(5)

        # Only consume complete (\n-terminated) lines. A chunk can end on
        # a partial write: the writer flushed bytes but not the terminator
        # yet. If we advanced scan_offset past the fragment, we would
        # emit that fragment as a "line", fail to parse it, and on the
        # next read pick up only the remainder (also unparseable), missing
        # the real match. Matches _emit_complete_lines in emails since
        # --follow.
        lines = chunk.split(b"\n")
        complete, tail = lines[:-1], lines[-1]
        scan_offset += len(chunk) - len(tail)

        for raw in complete:
            stripped = raw.strip()
            if not stripped:
                continue
            try:
                entry = json.loads(stripped)
            except json.JSONDecodeError:
                # Corrupt line in the journal. Skip; `emails since` is
                # the surface that exits 5 on corruption.
                continue
            if entry.get("subject") == subject:
                matched = entry
                break
        if matched is not None:
            break
        time.sleep(0.5)

    if matched is None:
        hint = (f"dispatched from primitive.dev but not observed locally "
                f"within {args.timeout}s; check DNS, inbound port 25, "
                f"and container health")
        if args.json:
            print(json.dumps({
                "ok": False, "error": "timeout", "tag": tag,
                "dispatched_at": dispatched_at,
                "timeout_seconds": args.timeout, "hint": hint,
            }))
        else:
            print(hint, file=sys.stderr)
        sys.exit(6)

    elapsed_ms = int((time.monotonic() - poll_start) * 1000)
    if args.json:
        print(json.dumps({
            "ok": True, "tag": tag, "subject": subject,
            "from": from_addr, "to": to_addr,
            "dispatched_at": dispatched_at,
            "received_at": matched.get("received_at"),
            "seq": matched.get("seq"),
            "elapsed_ms": elapsed_ms,
        }))
    else:
        # Multi-line summary so the operator can see at a glance that the
        # message genuinely round-tripped externally: the From: address is
        # primitive.dev's sender, the To: is their claimed subdomain, and
        # the subject is the server-stamped tag. Terse one-liner left
        # ambiguous whether the message came from outside or was synthesized
        # locally (reported in blind-install test #5).
        seq = matched.get("seq")
        print(f"Received in {elapsed_ms / 1000:.2f}s (seq {seq}).")
        if from_addr:
            print(f"  From:    {from_addr}")
        if to_addr:
            print(f"  To:      {to_addr}")
        print(f"  Subject: {subject}")


def get_install_path():
    """Resolve the primitivemail install directory. Sudo-aware: when
    invoked under `sudo`, resolves against the original user's home
    rather than /root (where the install does not live)."""
    if os.environ.get("PRIMITIVEMAIL_DIR"):
        return Path(os.environ["PRIMITIVEMAIL_DIR"])
    return _invoking_user_home() / "primitivemail"


def cmd_restart(args):
    install_dir = get_install_path()
    compose_file = install_dir / "docker-compose.yml"

    if not compose_file.exists():
        print(f"No docker-compose.yml found at {install_dir}")
        sys.exit(1)

    print("Reloading PrimitiveMail (only changed containers restart)...")
    result = subprocess.run(
        ["docker", "compose", "up", "-d"],
        cwd=install_dir,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(f"Failed: {result.stderr.strip()}")
        sys.exit(1)
    print("Done.")


def _build_parser():
    parser = argparse.ArgumentParser(
        prog="primitive",
        description="PrimitiveMail CLI - manage your self-hosted inbox",
    )
    parser.add_argument("--path", help="Path to maildata directory")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("version", help="Show version")

    emails = sub.add_parser("emails", help="Inspect the email inbox")
    emails_sub = emails.add_subparsers(dest="emails_command")

    emails_sub.add_parser("status", help="Count emails, show latest sender/time")

    p_list = emails_sub.add_parser("list", help="List recent emails from the journal")
    p_list.add_argument("--limit", type=int, default=None,
                        help="Return at most N entries. Default 20. Use 0 for unlimited.")
    p_list.add_argument("--since", type=int, default=None,
                        help="Only entries with seq > <seq>. Default 0. "
                             "For live tailing, see `emails since --follow`.")
    p_list.add_argument("--domain", default=None,
                        help="Filter by recipient domain.")
    p_list.add_argument("--from", dest="from_addr", default=None,
                        help='Substring match on "from_address".')
    p_list.add_argument("--json", action="store_true",
                        help="Emit one JSON object per line on stdout "
                             "(matches emails.jsonl format).")

    p_read = emails_sub.add_parser("read", help="Read one email in json, raw, text, or html")
    p_read.add_argument(
        "selector", nargs="?", default=None,
        help="Canonical id (20260417T101203Z-a1b2c3d4), seq number (integer), "
             "or short id prefix (requires --prefix). Omit when --latest is set.",
    )
    p_read.add_argument("--latest", action="store_true",
                        help="Read the most recent email. Omits <selector>.")
    p_read.add_argument("--prefix", action="store_true",
                        help="Treat a non-canonical selector as an id prefix. "
                             "Ambiguous prefixes (two or more matches) exit 3.")
    p_read.add_argument("--format", choices=["json", "raw", "text", "html"], default="json")
    p_read.add_argument("--domain", default=None,
                        help="Disambiguate when the id exists under two or more domains.")

    p_since = emails_sub.add_parser(
        "since",
        help="Stream journal entries with seq > <seq>. "
             "For filtered/formatted output, see `emails list --since`.",
    )
    p_since.add_argument("seq", help="Emit entries with seq > <seq>. Use 0 from the start.")
    p_since.add_argument("--follow", "-f", action="store_true",
                         help="After catch-up, keep streaming new entries.")
    p_since.add_argument("--limit", type=int, default=None,
                         help="Stop after N catch-up entries (0 = unlimited).")

    p_count = emails_sub.add_parser(
        "count", help="Count matching emails. Prints a single integer.",
    )
    p_count.add_argument("--domain", default=None, help="Filter by recipient domain.")
    p_count.add_argument("--since", default=None,
                         help="ISO-8601 received_at lower bound (inclusive, UTC).")
    p_count.add_argument("--from", dest="from_addr", default=None,
                         help="Substring match on from_address.")

    p_test = emails_sub.add_parser(
        "test",
        help="Send a real external test email via primitive.dev to your "
             "claimed subdomain and wait for it to arrive",
    )
    # --wait and --no-wait are mutually exclusive. argparse exits with 2 on
    # conflict, which is the behavior the spec wants.
    wait_group = p_test.add_mutually_exclusive_group()
    wait_group.add_argument(
        "--wait", action="store_true", dest="wait", default=True,
        help="Block until the email arrives locally or the timeout elapses (default).",
    )
    wait_group.add_argument(
        "--no-wait", action="store_false", dest="wait",
        help="Dispatch and exit immediately without polling the journal.",
    )
    p_test.add_argument(
        "--timeout", type=int, default=30,
        help="Max seconds to wait when --wait is set. Default 30. Range 5 to 120.",
    )
    p_test.add_argument(
        "--json", action="store_true",
        help="Emit one JSON object on stdout describing the result.",
    )

    # Hidden compatibility alias for the pre-rename command. Omitting `help=`
    # keeps the descriptive row out of `primitive --help` so agents reading the
    # help surface do not pick it up; the name still resolves as a valid
    # command, prints a deprecation notice, and forwards to `emails status`.
    # Drop one release after `emails status` ships.
    sub.add_parser("emails-status")

    sub.add_parser("restart", help="Reload config and restart changed containers")

    return parser


def main():
    parser = _build_parser()
    args = parser.parse_args()

    if args.command == "version":
        cmd_version(args)
    elif args.command == "emails-status":
        cmd_emails_status_alias(args)
    elif args.command == "emails":
        sub = getattr(args, "emails_command", None)
        if sub == "status":
            cmd_emails_status(args)
        elif sub == "list":
            cmd_emails_list(args)
        elif sub == "read":
            cmd_emails_read(args)
        elif sub == "since":
            cmd_emails_since(args)
        elif sub == "count":
            cmd_emails_count(args)
        elif sub == "test":
            cmd_emails_test(args)
        else:
            parser.parse_args(["emails", "--help"])
            sys.exit(1)
    elif args.command == "restart":
        cmd_restart(args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()

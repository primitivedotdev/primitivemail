# PrimitiveMail Configuration
# Copy to .env and adjust values

# Server hostname and domain (optional - defaults to localhost)
# MYHOSTNAME=mx.yourdomain.com
# MYDOMAIN=yourdomain.com

# IP literal support (optional - receive mail at user@[IP] without DNS)
# ENABLE_IP_LITERAL=true
# IP_LITERAL=203.0.113.10

# Webhook (optional - without these, standalone mode accepts all valid emails)
# WEBHOOK_URL=https://your-api.example.com/webhook/email
# WEBHOOK_SECRET=your-secret-key
# WEBHOOK_EXTRA_HEADERS={"x-custom-header": "value"}  # JSON object of extra headers to send

# Storage for large emails >3MB (optional - S3, R2, MinIO, Supabase Storage, etc.)
# Without this, large emails are sent inline via webhook
# STORAGE_URL=https://s3.amazonaws.com/your-bucket/emails
# STORAGE_KEY=your-storage-auth-key
# STORAGE_AUTH_STYLE=s3    # "s3" or "supabase"

# --- Sender filtering ---
# Restrict which senders can deliver mail to this server.
# Comma-separated list of domains and/or full addresses.
# If empty/unset, all senders are accepted.
# NOTE: This is an envelope address allowlist, not cryptographic verification.
# For actual sender authentication, enable SPOOF_PROTECTION.
# ALLOWED_SENDER_DOMAINS=example.com,trusted.org
# ALLOWED_SENDERS=specific-person@gmail.com,alerts@service.io
# ALLOW_BOUNCES=true    # Accept bounce messages (empty MAIL FROM)

# --- Recipient filtering ---
# Restrict which recipients this server accepts mail for.
# If empty/unset, all recipients at configured domains are accepted.
# ALLOWED_RECIPIENTS=inbox@example.com,alerts@example.com

# --- Spoof protection (SPF/DKIM/DMARC) ---
# Verifies senders are who they claim to be using DNS-based authentication.
#   "off"      - No checks (default, for testing/development)
#   "monitor"  - Check and add result headers, but accept all mail
#   "standard" - Enforce the sender's own published DMARC policy (recommended)
#   "strict"   - Reject on any SPF/DKIM/DMARC failure
# SPOOF_PROTECTION=off

# --- TLS ---
# Self-signed certificate is auto-generated at startup.
# Provide your own cert/key to use a real certificate (e.g. from Let's Encrypt)
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# --- Mail storage (standalone mode) ---
# Directory where standalone mode saves incoming mail
# MAIL_DIR=/mail/incoming

# Logging (optional - Loki-compatible endpoint)
# LOKI_URL=https://your-loki-endpoint/loki/api/v1/push
# LOKI_USER=your-user
# LOKI_KEY=your-api-key

# Metrics (optional - Prometheus remote write endpoint)
# PROMETHEUS_URL=https://your-prometheus-endpoint/api/prom/push
# PROMETHEUS_USER=your-user
# PROMETHEUS_KEY=your-api-key

# Image overrides (optional - default install pulls published GHCR images)
# PRIMITIVEMAIL_IMAGE=ghcr.io/primitivedotdev/primitivemail:edge
# PRIMITIVEMAIL_WATCHER_IMAGE=ghcr.io/primitivedotdev/primitivemail-watcher:edge

# --- Postfix log to stdout (optional) ---
# Mirror Postfix logs to stdout for container log collectors (Datadog, CloudWatch, etc.)
# Postfix still writes to /var/log/postfix.log regardless — this just adds stdout output.
# POSTFIX_LOG_STDOUT=true

# --- Datadog APM tracing (optional) ---
# Requires: pip install ddtrace (or INSTALL_DDTRACE=true Docker build arg)
# Requires: Datadog Agent running on localhost:8126
# DATADOG_TRACING_ENABLED=true
# DD_SERVICE=milter
# DD_ENV=staging
# DD_TRACE_AGENT_URL=http://localhost:8126
